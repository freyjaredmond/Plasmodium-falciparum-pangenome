import pandas as pd
import matplotlib.pyplot as plt
from matplotlib.patches import Patch
from scipy import stats
import numpy as np
from scipy.stats import chi2_contingency


##read in data
matrix=pd.read_csv("PSEUDO/GET_PANGENES_OUTPUT_16_PSEUDO/Clusters_renamed_pseudo.tsv", sep="\t", index_col=0)
interpro=pd.read_csv("PSEUDO/interpro_sixteen.txt", sep="\t")

#filter for genes that have interpro id in the interpro_id dataset - only gets the gene_ids once if they are unique
interpro_notna = interpro[
    interpro["Interpro ID"].notna() &
    (interpro["Interpro ID"] != "N/A")
]
gene_ids=interpro_notna["Gene ID"]
interpro_id=list(gene_ids.unique())

print(f"Total number of genes with InterPro IDs:{len(interpro_id)}")
#filter the pangene matrix- get dictionary of occupancy and the corresponding number of pangenes with interpro ids
count_id={}
count_total={}
cloud_genes_no_inter=[]
cloud_genes_with_inter=[]
core_genes_with_inter=[]
core_genes_no_inter=[]


#check if cluster id has a valid interpro
for cluster in matrix.columns:
    occupancy = (matrix[cluster] != "-").sum()
    count_total[occupancy] = count_total.get(occupancy, 0) + 1 #get the total cluster count for that occupancy
    if cluster in interpro_id:
        count_id[occupancy]=count_id.get(occupancy,0)+1
        if occupancy in (1,2):
            cloud_genes_with_inter.append(cluster)
        elif occupancy==16:
            core_genes_with_inter.append(cluster)
               
    else:
        if occupancy in (1, 2):  
            cloud_genes_no_inter.append(cluster)
        elif occupancy == 16:  
            core_genes_no_inter.append(cluster)
 


#sanity check
print(f"Core total:{len(core_genes_no_inter+core_genes_with_inter)}\n")
print(f"Cloud total:{len(cloud_genes_no_inter+cloud_genes_with_inter)}\n")


##get the percentage values
percentage={}
for occupancy, counts in count_id.items():
    percent=(counts/count_total[occupancy])*100
    percentage[occupancy]=percent
percentage_sorted = dict(sorted(percentage.items()))


#chi2 test

table = [
    [len(core_genes_with_inter), len(core_genes_no_inter)],
    [len(cloud_genes_with_inter), len(cloud_genes_no_inter)]
]


chi2, p_val, dof, expected = chi2_contingency(table)
print(f"Chi2:{chi2}\n")
if p_val <0.05:
    print(f"Significant p-value:{p_val}")
else:
    print(f"Not significant:{p_val}")


#cramers_v
#V = sqrt(chi2 / (n × min(r-1, c-1)))
n = (len(core_genes_no_inter)+len(core_genes_with_inter)+len(cloud_genes_no_inter)+len(cloud_genes_with_inter))
cramers_v = np.sqrt(chi2 / n)
print(f"Cramers_v:{cramers_v}")

##make the barchart


#colour classification
def classify_colour(x):
    if x == 16:
        return "red"
    elif x == 15:
        return "orange"
    elif x in (1, 2):
        return "blue"
    else:
        return "green"
bar_colours=[classify_colour(x) for x in percentage_sorted.keys()]
x_ticks=list(range(1,17))
fig,ax=plt.subplots(figsize=(12,6))
ax.bar(percentage_sorted.keys(), percentage_sorted.values(), color=bar_colours)
# significance bar connecting cloud (x=1.5 midpoint) to core (x=16)
x1 = 1.5   
x2 = 16    
y = 105    
h = 1     

ax.plot([x1, x1, x2, x2], [y, y+h, y+h, y], lw=1.5, color="black")
ax.text((x1+x2)/2, y+h+0.5, "***", ha="center", va="bottom", fontsize=12)

ax.set_ylim(0, 115)
ax.set_xlabel("Pangene Occupancy")
ax.set_ylabel("Percentage of pangenes with an InterPro ID (%)")
ax.set_xticks(x_ticks)
ax.set_xlim(left=0.5, right=16.5)
ax.set_yticks([0, 20, 40, 60, 80, 100])


legend_elements = [
    Patch(facecolor="red", label="Core"),    
    Patch(facecolor="orange", label="Soft-core"),
    Patch(facecolor="green", label="Shell"),
    Patch(facecolor="blue", label="Cloud"),
]
ax.legend(handles=legend_elements,bbox_to_anchor=(1.14, 1), loc="upper right")
plt.show()
   
print(count_total)
print(count_id)


fig.savefig("PSEUDO/GRAPHS/Interpro_graph_sixteen.png", dpi=300)


#Create tsvs for core/cloud genes without valid interpro
no_tsv=pd.DataFrame({"Core":pd.Series(core_genes_no_inter),"Cloud":pd.Series(cloud_genes_no_inter)})#use series to add na when different lengths
no_tsv.to_csv("No_interpro_sixteen.tsv", sep="\t")

core_percent = len(core_genes_with_inter) / (len(core_genes_with_inter) + len(core_genes_no_inter)) * 100
cloud_percent = len(cloud_genes_with_inter) / (len(cloud_genes_with_inter) + len(cloud_genes_no_inter)) * 100
print(f"Core % with InterPro: {core_percent:.2f}%")
print(f"Cloud % with InterPro: {cloud_percent:.2f}%")
print(f"Core: {len(core_genes_with_inter)} with / {len(core_genes_no_inter)} without = {core_percent:.1f}%")
print(f"Cloud: {len(cloud_genes_with_inter)} with / {len(cloud_genes_no_inter)} without = {cloud_percent:.1f}%")

#### check distribution of cloud/core for rifs
prod=pd.read_csv("PSEUDO/product_des.txt", sep="\t")
prod_dict=dict(zip(prod["Gene ID"], prod["Product Description"]))

table_data=[]
for cluster in matrix.columns:
    occupancy = (matrix[cluster] != "-").sum()
    if occupancy==16:
        group= "core"
    elif occupancy ==15:
        group="soft-core"
    elif occupancy in (1,2):
        group="cloud"
    else:
        group="shell"
    is_rif = prod_dict.get(cluster, "") == "rifin" #returns a boolian
    table_data.append({"Pangene":cluster,
                       "Occupancy":occupancy,
                       "Classification":group,
                       "Is_rif":is_rif})
df=pd.DataFrame(table_data)
print(df.head())

#percentage of rif genes within core vs cloud vs shell
core_df = df[df["Classification"]=="core"]
cloud_df = df[df["Classification"]=="cloud"]
shell_df = df[df["Classification"]=="shell"]

core_rif_percent = core_df["Is_rif"].mean()*100
cloud_rif_percent = cloud_df["Is_rif"].mean()*100
shell_rif_percent = shell_df["Is_rif"].mean()*100

print(f"Core: {core_df['Is_rif'].sum()}/{len(core_df)} rif = {core_rif_percent:.2f}%")
print(f"Cloud: {cloud_df['Is_rif'].sum()}/{len(cloud_df)} rif = {cloud_rif_percent:.2f}%")
print(f"Shell: {shell_df['Is_rif'].sum()}/{len(shell_df)} rif = {shell_rif_percent:.2f}%")